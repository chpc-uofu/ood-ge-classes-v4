<%-
  emailcmd = '/uufs/chpc.utah.edu/sys/bin/CHPCEmailLookup.sh ' + ENV["USER"]
  emailaddr = %x[ #{emailcmd}]
-%>

batch_connect:
  template: "basic"
script:
  email: <%= emailaddr %>
  native:
  <%- if my_queue == "coe-class-grn" -%>
    - "-N"
    - "1"
    - "-n"
    - 8
    - "-A"
    - "ece6545"
    - "-p"
    - "coe-class-grn"
    - "--qos"
    - "coe-class-grn"
    - "--mem"
    - "32G"
  <%- elsif my_queue == "coestudent-shared-np" -%>
    - "-N"
    - "1"
    - "-n"
    - 8
    - "-A"
    - "coestudent-np"
    - "-p"
    - "coestudent-shared-np"
    - "--mem"
    - "32G"
  <%- elsif my_queue == "coe-gpu-class-grn" -%>
    - "-N"
    - "1"
    - "-n"
    - 8
    - "-A"
    - "ece6545"
    - "-p"
    - "coe-gpu-class-grn"
    - "--qos"
    - "coe-gpu-class-grn"
    - "--mem"
    - "32G"
    - "--gres=gpu:rtxpr4000bl:1"
  <%- elsif my_queue == "notchpeak-gpu" -%>
    - "-N"
    - "1"
    - "-n"
    - 8
    - "-A"
    - "notchpeak-gpu"
    - "-p"
    - "notchpeak-gpu"
    - "--qos"
    - "notchpeak-gpu"
    - "--mem"
    - "32G"
    - "--gres=gpu:1"
  <%- elsif my_queue == "kingspeak-gpu" -%>
    - "-N"
    - "1"
    - "-n"
    - 8
    - "-A"
    - "kingspeak-gpu"
    - "-p"
    - "kingspeak-gpu"
    - "--qos"
    - "kingspeak-gpu"
    - "--mem"
    - "32G"
    - "--gres=gpu:1"
  <%- elsif my_queue == "lonepeak-gpu" -%>
    - "-N"
    - "1"
    - "-n"
    - 2
    - "-A"
    - "lonepeak-gpu"
    - "-p"
    - "lonepeak-gpu"
    - "--qos"
    - "lonepeak-gpu"
    - "--mem"
    - "16G"
    - "--gres=gpu:1"
    - "--reservation=ece6545"
<%- end -%>
